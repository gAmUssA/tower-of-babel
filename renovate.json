{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "enabledManagers": [
    "docker-compose",
    "gradle",
    "npm",
    "pep621"
  ],
  "packageRules": [
    {
      "groupName": "order-service dependencies",
      "matchFileNames": [
        "services/order-service/**"
      ],
      "addLabels": [
        "java"
      ]
    },
    {
      "groupName": "inventory-service dependencies",
      "matchFileNames": [
        "services/inventory-service/**"
      ],
      "addLabels": [
        "python"
      ]
    },
    {
      "groupName": "analytics-api dependencies",
      "matchFileNames": [
        "services/analytics-api/**"
      ],
      "addLabels": [
        "node"
      ]
    },
    {
      "groupName": "infrastructure container images",
      "matchManagers": [
        "docker-compose"
      ],
      "addLabels": [
        "docker"
      ]
    },
    {
      "groupName": "confluent packages",
      "matchPackageNames": [
        "/^com\\.confluent/",
        "/^io\\.confluent/",
        "/^confluentinc\\//"
      ]
    },
    {
      "groupName": "spring packages",
      "matchPackageNames": [
        "/^org\\.springframework/",
        "/^org\\.springdoc/"
      ]
    },
    {
      "groupName": "kafka packages",
      "matchPackageNames": [
        "/^org\\.apache\\.kafka/",
        "/kafka/"
      ]
    },
    {
      "matchManagers": [
        "docker-compose"
      ],
      "pinDigests": true
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "addLabels": [
        "breaking-change"
      ]
    }
  ],
  "ignoreDeps": [
    "org.jetbrains.kotlin:kotlin-gradle-plugin"
  ],
  "labels": [
    "dependencies"
  ],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "schedule": [
    "every weekend"
  ],
  "timezone": "America/New_York",
  "dependencyDashboard": true,
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",
  "rangeStrategy": "auto",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "before 4am on the first day of the month"
    ]
  }
}
